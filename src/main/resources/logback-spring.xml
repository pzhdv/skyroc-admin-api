<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback 配置文件
    说明：用于精细化日志配置，包括 ERROR 独立文件、异步日志、格式优化等
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ========================= 属性定义 ========================= -->
    <!-- 项目名称，从 spring.application.name 读取，便于项目复用 -->
    <property name="APP_NAME" value="${spring.application.name:-application}"/>
    <!-- 业务代码基础包名 -->
    <property name="APP_BASE_PACKAGE" value="${app.base-package}"/>
    <!-- 日志保留天数 -->
    <property name="LOG_MAX_HISTORY" value="30"/>
    <!-- 单个日志文件最大大小 -->
    <property name="LOG_MAX_FILE_SIZE" value="100MB"/>
    <!-- 日志总大小上限 -->
    <property name="LOG_TOTAL_SIZE_CAP" value="3GB"/>

    <!-- ========================= 开发环境属性 ========================= -->
    <springProfile name="dev">
        <property name="LOG_LEVEL" value="DEBUG"/>
        <property name="LOG_FILE_PATH" value="logs"/>
    </springProfile>

    <!-- ========================= 生产环境属性 ========================= -->
    <springProfile name="prod">
        <property name="LOG_LEVEL" value="INFO"/>
        <property name="LOG_FILE_PATH" value="${LOG_PATH:-/var/log/skyroc-admin}"/>
    </springProfile>

    <!-- ========================= 控制台格式（带颜色，ANSI转义码） ========================= -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%5p) %boldMagenta(${PID:- }) %boldCyan(---) [%15.15t] %boldCyan(%-40.40logger{39}) : %m%n%ex"/>

    <!-- 文件日志格式（JSON风格，便于日志收集和分析） -->
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p ${PID:- } --- [%t] %-40.40logger{39} : %m%n%ex"/>

    <!-- ========================= Console 控制台输出 ========================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 开发环境打印所有级别，生产环境只打印 WARN 及以上 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${LOG_LEVEL}</level>
        </filter>
    </appender>

    <!-- ========================= FILE 普通日志文件（INFO+） ========================= -->
    <appender name="FILE_INFO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- 日志文件路径 -->
        <file>${LOG_FILE_PATH}/${APP_NAME}.log</file>
        <!-- 日志格式 -->
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 日志过滤：只记录 INFO 及以上 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <!-- 滚动策略：按日期 + 大小 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ========================= FILE_ERROR ERROR 级别日志（独立文件） ========================= -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <!-- ERROR 日志单独文件 -->
        <file>${LOG_FILE_PATH}/${APP_NAME}-error.log</file>
        <!-- 日志格式 -->
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 日志过滤：只记录 ERROR -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <!-- 滚动策略：按日期 + 大小 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${LOG_MAX_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ========================= ASYNC_INFO 异步普通日志 ========================= -->
    <appender name="ASYNC_INFO" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 引用 FILE_INFO appender -->
        <appender-ref ref="FILE_INFO"/>
        <!-- 队列容量，高并发场景可调大 -->
        <queueSize>512</queueSize>
        <!-- 队列满时策略：阻塞而非丢弃 -->
        <neverBlock>false</neverBlock>
        <!-- 队列满时开始丢弃阈值（20%，队列满80%开始丢弃） -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 包含调用堆栈信息（关闭以提升性能） -->
        <includeCallerData>false</includeCallerData>
    </appender>

    <!-- ========================= ASYNC_ERROR 异步 ERROR 日志 ========================= -->
    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 引用 FILE_ERROR appender -->
        <appender-ref ref="FILE_ERROR"/>
        <!-- 队列容量 -->
        <queueSize>512</queueSize>
        <!-- 队列满时策略 -->
        <neverBlock>false</neverBlock>
        <discardingThreshold>0</discardingThreshold>
        <!-- ERROR 日志建议包含调用堆栈 -->
        <includeCallerData>true</includeCallerData>
    </appender>

    <!-- ========================= 日志级别配置 ========================= -->

    <!-- 开发环境配置 -->
    <springProfile name="dev">
        <!-- 根日志级别 -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_INFO"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>

        <!-- 业务代码：DEBUG 级别 -->
        <logger name="${APP_BASE_PACKAGE}" level="DEBUG" additivity="false"/>

        <!-- Spring 框架：WARN 级别 -->
        <logger name="org.springframework" level="WARN"/>

        <!-- Druid 连接池：INFO 级别 -->
        <logger name="com.alibaba.druid" level="INFO"/>
    </springProfile>

    <!-- 生产环境配置 -->
    <springProfile name="prod">
        <!-- 根日志级别 -->
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="ASYNC_INFO"/>
            <appender-ref ref="ASYNC_ERROR"/>
        </root>

        <!-- 业务代码：INFO 级别 -->
        <logger name="${APP_BASE_PACKAGE}" level="INFO" additivity="false"/>

        <!-- Spring 框架：ERROR 级别 -->
        <logger name="org.springframework" level="ERROR"/>

        <!-- Druid 连接池：WARN 级别 -->
        <logger name="com.alibaba.druid" level="WARN"/>
    </springProfile>

</configuration>
